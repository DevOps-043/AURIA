VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

VITE_BILLING_PROVIDER=disabled
BILLING_PROVIDER=disabled
BILLING_WEBHOOK_SECRET=change-me
BILLING_CUSTOM_CHECKOUT_URL=
BILLING_CUSTOM_PORTAL_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ─── GitHub OAuth ────────────────────────────────────────────────────
# GitHub OAuth credentials are configured in the Supabase Dashboard,
# NOT here. Go to: Supabase Dashboard → Authentication → Providers → GitHub
#
# Steps:
# 1. Create a GitHub OAuth App at https://github.com/settings/developers
#    - Callback URL: https://<your-project>.supabase.co/auth/v1/callback
# 2. Paste the Client ID and Client Secret in Supabase Dashboard
#
# The variable below is OPTIONAL — only needed if Edge Functions
# need server-to-server GitHub access (e.g., webhook processing).
# GITHUB_APP_PRIVATE_KEY=

# ─── AI Model Providers ──────────────────────────────────────────────
# Todos los modelos se consumen via Google Cloud Vertex AI Model Garden.
# Con Vertex AI tienes acceso a: Gemini, Claude, Mistral y GPT OSS.
# Autenticación: Application Default Credentials (gcloud auth application-default login)

# Google Cloud Vertex AI (recomendado — acceso a todos los modelos)
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# Google Gemini API directa (fallback — solo modelos Gemini, sin GCP)
GEMINI_API_KEY=
